# Transcription provider: whisper or mock
# whisper requires OPENAI_API_KEY. mock is useful for local UI testing.
TRANSCRIPTION_PROVIDER=mock
OPENAI_API_KEY=

# Note generation provider: groq, openrouter, or mock
# groq requires GROQ_API_KEY. openrouter requires OPENROUTER_API_KEY.
LLM_PROVIDER=mock
GROQ_API_KEY=
OPENROUTER_API_KEY=
